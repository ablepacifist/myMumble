# ============================================
# Mumble Bridge Service Configuration
# ============================================

# WebSocket server port (web clients connect here)
WS_PORT=3080

# Mumble server connection
MUMBLE_HOST=127.0.0.1
MUMBLE_PORT=64738

# MySQL (Mumble's database - read access for user lookups)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mumble
MYSQL_PASSWORD=mumble_pass_2026
MYSQL_DATABASE_MUMBLE=mumble_server
MYSQL_DATABASE_BRIDGE=mumble_bridge

# Lexicon API (your existing backend)
# Production via PlayIt tunnel (Cloudflare DNS not resolving locally)
LEXICON_API_URL=http://147.185.221.24:15856
# When Cloudflare DNS works: https://api.alex-dyakin.com

# Bridge settings
LOG_LEVEL=debug
BOT_COMMAND_PREFIX=!

# Superuser names (comma-separated) — only these users can create/delete channels
SUPERUSER_NAMES=alex
